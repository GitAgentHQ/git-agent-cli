+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if gen.lastReq == nil {
+		t.Fatal("generator was not called")
+	}
+	n := len(gen.lastReq.Diff.Content)
+	if n == 0 {
+		t.Fatal("amend byte cap truncated the diff to empty")
+	}
