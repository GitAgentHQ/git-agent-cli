+	signalSent := time.Now()
+	if err := c.Process.Signal(os.Interrupt); err != nil {
+		t.Fatalf("send SIGINT: %v", err)
+	}
+
+	done := make(chan error, 1)
+	go func() { done <- c.Wait() }()
+
+	var waitErr error
+	select {
+	case waitErr = <-done:
+	case <-time.After(2 * time.Second):
+		_ = c.Process.Kill()
+		t.Fatalf("subprocess did not exit within 2s of SIGINT\nstderr: %s", stderr.String())
+	}
