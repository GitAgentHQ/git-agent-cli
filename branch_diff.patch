+	// never read. Inheriting os.Environ() risks pulling in CLIPROXYAPI_TOKEN
+	// or other shell exports that change credential resolution.
+	c.Env = []string{
+		"PATH=" + os.Getenv("PATH"),
+		"HOME=" + t.TempDir(),
+		"XDG_CONFIG_HOME=" + t.TempDir(),
+	}
