+func truncationLimitDesc(maxLines, maxBytes int) string {
+	if maxLines > 0 {
+		return fmt.Sprintf("max %d lines / %d bytes", maxLines, maxBytes)
+	}
+	return fmt.Sprintf("max %d bytes", maxBytes)
+}
